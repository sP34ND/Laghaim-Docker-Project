# IP the game client uses to reach zone servers (Connector advertises this in ZONE_INFO).
# Same PC as Docker: 127.0.0.1
# Client on another machine: your Windows host LAN IP (e.g. 192.168.1.50)
GAME_HOST_IP=127.0.0.1

# Inside Docker: address game servers listen on (0.0.0.0 required for port forwarding from Windows host)
BIND_IP=0.0.0.0

# MySQL root password (must match across mysql + laghaim services)
MYSQL_ROOT_PASSWORD=laghaimofficial

# Optional: expose MySQL on host for debugging (default 3307 to avoid local 3306 conflicts)
MYSQL_PUBLISH_PORT=3307

# minimal = Connector + Messenger + Helper + 2 zones (recommended)
# full    = all 22 zones via serverrestart.sh (heavy)
LAGHAIM_MODE=minimal

# Must match Game.exe client build
CLIENT_VERSION=3034

# Raise if running LAGHAIM_MODE=full
LAGHAIM_MEMORY_LIMIT=4g
